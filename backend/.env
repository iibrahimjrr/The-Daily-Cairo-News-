APP_NAME="The Daily Cairo"
APP_ENV=local
APP_KEY=base64:iOTziC0u/f5dRm6y8m+KaGvnzOdgNcfV+ARineemJdg=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=daily_cairo
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optional - for caching/queues in production)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@dailycairo.com"
MAIL_FROM_NAME="${APP_NAME}"

# Pusher (optional - for real-time)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Meilisearch (optional - falls back to DB search)
SCOUT_DRIVER=database
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
